@startuml
skinparam componentStyle rectangle
skinparam monochrome false
skinparam shadowing false
skinparam defaultTextAlignment left

package "simulation" {
  [world]
  [adapter]
  [loader]
  [external_bridge]
  [ros2_bridge_stub]
  [carla_bridge_stub]
}
package "perception" {
  [sensor_model]
  [fusion_engine]
  [track_manager]
  [occupancy_grid]
}
package "prediction" {
  [intention]
  [constant_velocity]
  [interaction]
  [scene_risk_assessor]
}
package "planning" {
  [behavior_fsm]
  [lane_change_manager]
  [behavior_planner]
  [behavior_tree]
  [speed_planner]
  [trajectory_stitcher]
  [trajectory_planner]
}
package "control" {
  [controller]
}
package "runtime" {
  [autonomy_stack]
  [mission_manager]
  [event_logger]
  [decision_trace_writer]
  [report_writer]
  [evaluator]
}
package "safety" {
  [guardian]
}

[world] --> [sensor_model]
[sensor_model] --> [fusion_engine]
[sensor_model] --> [track_manager]
[fusion_engine] --> [occupancy_grid]
[track_manager] --> [intention]
[intention] --> [constant_velocity]
[constant_velocity] --> [scene_risk_assessor]
[occupancy_grid] --> [scene_risk_assessor]
[scene_risk_assessor] --> [behavior_tree]
[behavior_tree] --> [behavior_planner]
[behavior_planner] --> [speed_planner]
[speed_planner] --> [trajectory_stitcher]
[trajectory_stitcher] --> [trajectory_planner]
[trajectory_planner] --> [guardian]
[guardian] --> [controller]
[controller] --> [adapter]
[autonomy_stack] --> [external_bridge]
[autonomy_stack] --> [ros2_bridge_stub]
[autonomy_stack] --> [carla_bridge_stub]
[autonomy_stack] --> [decision_trace_writer]
@enduml
